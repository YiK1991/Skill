# Encoding and line-ending enforcement for CJK-mixed repositories (P16 defense)
# Prevents sync-tool / editor truncation from corrupting multi-byte UTF-8 characters

# Markdown — plan docs, trackers, investigation reports
*.md    text eol=lf encoding=utf-8

# Python scripts
*.py    text eol=lf encoding=utf-8

# Config files
*.yaml  text eol=lf encoding=utf-8
*.yml   text eol=lf encoding=utf-8
*.json  text eol=lf encoding=utf-8
*.toml  text eol=lf encoding=utf-8

# JavaScript / Node
*.js    text eol=lf encoding=utf-8
*.cjs   text eol=lf encoding=utf-8
*.mjs   text eol=lf encoding=utf-8

# Shell scripts
*.sh    text eol=lf encoding=utf-8
